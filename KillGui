-- ── State ─────────────────────────────────────────────────────────
local scareMode    = false   -- true = 1 bullet near target, false = 3-bullet burst
local BURST_COUNT  = 3       -- bullets fired in normal kill mode
local BURST_DELAY  = 0.06    -- seconds between burst shots (below most rate-limit windows)
local POS_JITTER   = 0.4
local SCARE_JITTER = 2.5     -- larger jitter so scare shot misses the head

-- ── Mouse cursor: persistently unlocked while GUI is alive ─────────
-- Equipping a gun resets MouseBehavior to LockCenter every time.
-- This listener fires whenever anything changes it and immediately
-- forces it back to Default, so re-equipping the gun has no effect.
