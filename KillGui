local function getTeamLabel(player)
	if player.Team then
		return player.Team.Name, player.Team.TeamColor.Color
	end
	return "No Team", Color3.fromRGB(90, 90, 100)
end

local function makeTeamHeader(teamName, teamColor, layoutOrder)
	local header = Instance.new("Frame")
	header.Size                  = UDim2.new(1, 0, 0, 18)
	header.BackgroundColor3      = teamColor
	header.BackgroundTransparency = 0.55
	header.BorderSizePixel       = 0
	header.LayoutOrder           = layoutOrder
	header.Parent                = scrollFrame
	Instance.new("UICorner", header).CornerRadius = UDim.new(0, 3)

	local label = Instance.new("TextLabel")
	label.Size                   = UDim2.new(1, -8, 1, 0)
	label.Position               = UDim2.new(0, 6, 0, 0)
	label.BackgroundTransparency = 1
	label.TextColor3             = Color3.new(1,1,1)
	label.TextSize               = 9
	label.Font                   = Enum.Font.GothamBold
	label.Text                   = teamName:upper()
	label.TextXAlignment         = Enum.TextXAlignment.Left
	label.Parent                 = header
end

local function makePlayerRow(target, layoutOrder)
	local humanoid = target.Character and target.Character:FindFirstChild("Humanoid")
	local isAlive  = humanoid and humanoid.Health > 0

	local row = Instance.new("Frame")
	row.Name             = "Row_" .. target.Name
	row.Size             = UDim2.new(1, 0, 0, 32)
	row.BackgroundColor3 = Color3.fromRGB(26, 26, 33)
	row.BorderSizePixel  = 0
	row.LayoutOrder      = layoutOrder
	row.Parent           = scrollFrame
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 3)

	-- Head thumbnail (loaded async so the list doesn't freeze)
	local headIcon = Instance.new("ImageLabel")
	headIcon.Size                   = UDim2.new(0, 26, 0, 26)
	headIcon.Position               = UDim2.new(0, 3, 0.5, -13)
	headIcon.BackgroundColor3       = Color3.fromRGB(40, 40, 50)
	headIcon.BorderSizePixel        = 0
	headIcon.Image                  = ""  -- filled async below
	headIcon.ImageTransparency      = isAlive and 0 or 0.5
	headIcon.Parent                 = row
	Instance.new("UICorner", headIcon).CornerRadius = UDim.new(0, 3)

	task.spawn(function()
		-- GetUserThumbnailAsync yields; run in its own thread
		local ok, thumb = pcall(function()
			return players:GetUserThumbnailAsync(
				target.UserId,
				Enum.ThumbnailType.HeadShot,
				Enum.ThumbnailSize.Size48x48
			)
		end)
		if ok and headIcon.Parent then
			headIcon.Image = thumb
		end
	end)

	-- Username label
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size                   = UDim2.new(1, -100, 1, 0)
	nameLabel.Position               = UDim2.new(0, 33, 0, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text                   = target.Name
	nameLabel.TextColor3             = isAlive
		and Color3.fromRGB(210, 210, 210)
		or  Color3.fromRGB(100, 100, 115)
	nameLabel.TextSize               = 11
	nameLabel.Font                   = Enum.Font.Gotham
	nameLabel.TextXAlignment         = Enum.TextXAlignment.Left
	nameLabel.TextTruncate           = Enum.TextTruncate.AtEnd
	nameLabel.Parent                 = row

	-- Kill / Scare button
	if isAlive then
		local killBtn = Instance.new("TextButton")
		killBtn.Size             = UDim2.new(0, 54, 0, 22)
		killBtn.Position         = UDim2.new(1, -58, 0.5, -11)
		killBtn.BackgroundColor3 = Color3.fromRGB(155, 35, 35)
		killBtn.Text             = scareMode and "Scare" or "Kill"
		killBtn.TextColor3       = Color3.new(1,1,1)
		killBtn.TextSize         = 10
		killBtn.Font             = Enum.Font.GothamBold
		killBtn.BorderSizePixel  = 0
		killBtn.Parent           = row
		Instance.new("UICorner", killBtn).CornerRadius = UDim.new(0, 3)

		-- Keep label in sync if scare mode is toggled after list built
		scareBtn.MouseButton1Click:Connect(function()
			killBtn.Text             = scareMode and "Scare" or "Kill"
			killBtn.BackgroundColor3 = scareMode
				and Color3.fromRGB(50, 110, 50)
				or  Color3.fromRGB(155, 35, 35)
		end)

		killBtn.MouseButton1Click:Connect(function()
			killBtn.Active           = false
			killBtn.Text             = "…"
			killBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
			nameLabel.TextColor3     = Color3.fromRGB(130, 130, 140)
			killPlayer(target)
			task.delay(0.4, function()
				-- Rebuild list so dead state updates
				buildList(searchBox.Text)
			end)
		end)
	else
		-- Dead label
		local deadLabel = Instance.new("TextLabel")
		deadLabel.Size                   = UDim2.new(0, 54, 0, 22)
		deadLabel.Position               = UDim2.new(1, -58, 0.5, -11)
		deadLabel.BackgroundTransparency = 1
		deadLabel.Text                   = "Dead"
		deadLabel.TextColor3             = Color3.fromRGB(90, 90, 100)
		deadLabel.TextSize               = 10
		deadLabel.Font                   = Enum.Font.Gotham
		deadLabel.TextXAlignment         = Enum.TextXAlignment.Center
		deadLabel.Parent                 = row
	end
end

-- Rebuild list, filtered by search query
function buildList(query)
	query = (query or ""):lower()

	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	-- Group by team, filtered by search
	local groups = {}
	local order  = {}

	for _, player in ipairs(players:GetPlayers()) do
		if player ~= lp then
			-- Filter: show row only if name matches query (empty query = show all)
			if query == "" or player.Name:lower():find(query, 1, true) then
				local teamName, teamColor = getTeamLabel(player)
				if not groups[teamName] then
					groups[teamName] = { color = teamColor, members = {} }
					table.insert(order, teamName)
				end
				table.insert(groups[teamName].members, player)
			end
		end
	end

	table.sort(order)

	local layoutOrder = 0
	for _, teamName in ipairs(order) do
		local group = groups[teamName]
		makeTeamHeader(teamName, group.color, layoutOrder)
		layoutOrder += 1
		table.sort(group.members, function(a, b) return a.Name < b.Name end)
		for _, player in ipairs(group.members) do
			makePlayerRow(player, layoutOrder)
			layoutOrder += 1
		end
	end

	if layoutOrder == 0 then
		local empty = Instance.new("TextLabel")
		empty.Size                   = UDim2.new(1, 0, 0, 30)
		empty.BackgroundTransparency = 1
		empty.TextColor3             = Color3.fromRGB(90, 90, 105)
		empty.TextSize               = 11
		empty.Font                   = Enum.Font.Gotham
		empty.Text                   = query ~= "" and "No players match \"" .. query .. "\""
			or "No other players in server"
		empty.LayoutOrder            = 0
		empty.Parent                 = scrollFrame
	end
end

-- ── Wire up events ────────────────────────────────────────────────
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	buildList(searchBox.Text)
end)

killAllBtn.MouseButton1Click:Connect(function()
	killAllBtn.Active = false
	killAllBtn.Text   = "Running…"

	local targets = {}
	for _, player in ipairs(players:GetPlayers()) do
		if player ~= lp and player.Character then
			local h = player.Character:FindFirstChild("Humanoid")
			if h and h.Health > 0 then table.insert(targets, player) end
		end
	end
	-- Shuffle
	for i = #targets, 2, -1 do
		local j = math.random(i)
		targets[i], targets[j] = targets[j], targets[i]
	end

	task.spawn(function()
		for _, target in ipairs(targets) do
			killPlayer(target)
			buildList(searchBox.Text)
			task.wait(humanDelay())
		end
		print(("[DEMO] Done — fired at %d player(s)"):format(#targets))
		killAllBtn.Text   = scareMode and "Scare All" or "Kill All  (burst)"
		killAllBtn.Active = true
	end)
end)

players.PlayerAdded:Connect(function()   task.wait(1)   buildList(searchBox.Text) end)
players.PlayerRemoving:Connect(function() task.wait(0.1) buildList(searchBox.Text) end)

