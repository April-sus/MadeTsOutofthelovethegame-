	if uis.MouseBehavior ~= Enum.MouseBehavior.Default then
		uis.MouseBehavior = Enum.MouseBehavior.Default
	end
end)

-- ── Jitter / fire helpers ─────────────────────────────────────────
local function jitter(mag)
	return Vector3.new(
		(math.random() * 2 - 1) * mag,
		(math.random() * 2 - 1) * mag,
		(math.random() * 2 - 1) * mag
	)
end

local function humanDelay()
	return 0.3 + ((math.random() + math.random()) / 2) * 0.4
end

-- Fire BulletHit N times at a target (burst) or once near head (scare)
local function killPlayer(target)
	if not target or not target.Character then return end
	local head     = target.Character:FindFirstChild("Head")
	local humanoid = target.Character:FindFirstChild("Humanoid")
	if not head or not humanoid or humanoid.Health <= 0 then
		print("[DEMO] " .. target.Name .. " already dead or missing.") return
	end

	local currentTool = char:FindFirstChildWhichIsA("Tool")
	if not currentTool or not currentTool:FindFirstChild("SPH_Weapon") then
		print("[DEMO] No SPH gun equipped — server would reject.") return
	end

	if scareMode then
		-- Scare shot: 1 bullet with big jitter so it misses but player sees the hit effect
		local missPos  = head.Position + jitter(SCARE_JITTER)
		local originCF = char.HumanoidRootPart.CFrame * CFrame.new(jitter(1.5))
		bh:Fire(currentTool, { Position = missPos, Normal = Vector3.new(0,1,0), Instance = head }, originCF)
		print("[DEMO] Scare shot fired near " .. target.Name)
	else
		-- 3-bullet burst: fire BURST_COUNT times with a small delay between each
		-- Bypasses single-shot detection; each packet looks like a normal shot
		for i = 1, BURST_COUNT do
			if not target.Character then break end
			local h2 = target.Character:FindFirstChild("Head")
			if not h2 then break end
			local hitPos   = h2.Position + jitter(POS_JITTER)
			local originCF = char.HumanoidRootPart.CFrame * CFrame.new(jitter(1.5))
			bh:Fire(currentTool, { Position = hitPos, Normal = Vector3.new(0,1,0), Instance = h2 }, originCF)
			if i < BURST_COUNT then task.wait(BURST_DELAY) end
		end
		print(("[DEMO] %d-bullet burst fired at %s"):format(BURST_COUNT, target.Name))
	end
end

