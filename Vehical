-- ── Slider builder ────────────────────────────────────────────────
local function makeSlider(labelText, layoutOrder, minVal, maxVal, defaultVal, step, onChanged)
	local row = Instance.new("Frame")
	row.Size             = UDim2.new(1, 0, 0, 58)
	row.BackgroundColor3 = Color3.fromRGB(19, 19, 27)
	row.BorderSizePixel  = 0
	row.LayoutOrder      = layoutOrder
	row.Parent           = configPanel
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)

	local rowPad = Instance.new("UIPadding")
	rowPad.PaddingLeft  = UDim.new(0, 8)
	rowPad.PaddingRight = UDim.new(0, 8)
	rowPad.Parent       = row

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size               = UDim2.new(0.65, 0, 0, 20)
	nameLabel.Position           = UDim2.new(0, 0, 0, 8)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text               = labelText
	nameLabel.TextColor3         = Color3.fromRGB(160, 160, 195)
	nameLabel.TextSize           = 11
	nameLabel.Font               = Enum.Font.Gotham
	nameLabel.TextXAlignment     = Enum.TextXAlignment.Left
	nameLabel.Parent             = row

	local valLabel = Instance.new("TextLabel")
	valLabel.Size               = UDim2.new(0.35, 0, 0, 20)
	valLabel.Position           = UDim2.new(0.65, 0, 0, 8)
	valLabel.BackgroundTransparency = 1
	valLabel.Text               = step < 1 and string.format("%.1f", defaultVal) or tostring(defaultVal)
	valLabel.TextColor3         = Color3.fromRGB(120, 190, 255)
	valLabel.TextSize           = 11
	valLabel.Font               = Enum.Font.GothamBold
	valLabel.TextXAlignment     = Enum.TextXAlignment.Right
	valLabel.Parent             = row

	local trackBg = Instance.new("Frame")
	trackBg.Size             = UDim2.new(1, 0, 0, 6)
	trackBg.Position         = UDim2.new(0, 0, 0, 38)
	trackBg.BackgroundColor3 = Color3.fromRGB(32, 32, 46)
	trackBg.BorderSizePixel  = 0
	trackBg.Parent           = row
	Instance.new("UICorner", trackBg).CornerRadius = UDim.new(1, 0)

	local t0 = (defaultVal - minVal) / (maxVal - minVal)

	local trackFill = Instance.new("Frame")
	trackFill.Size             = UDim2.new(t0, 0, 1, 0)
	trackFill.BackgroundColor3 = Color3.fromRGB(90, 145, 255)
	trackFill.BorderSizePixel  = 0
	trackFill.Parent           = trackBg
	Instance.new("UICorner", trackFill).CornerRadius = UDim.new(1, 0)

	local thumb = Instance.new("Frame")
	thumb.Size        = UDim2.new(0, 14, 0, 14)
	thumb.AnchorPoint = Vector2.new(0.5, 0.5)
	thumb.Position    = UDim2.new(t0, 0, 0.5, 0)
	thumb.BackgroundColor3 = Color3.fromRGB(175, 205, 255)
	thumb.BorderSizePixel  = 0
	thumb.Parent      = trackBg
	Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

	local dragging = false

	local function applyX(absX)
		local t = math.clamp((absX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
		local raw = minVal + t * (maxVal - minVal)
		local val = math.clamp(math.floor(raw / step + 0.5) * step, minVal, maxVal)
		local displayT = (val - minVal) / (maxVal - minVal)
		trackFill.Size    = UDim2.new(displayT, 0, 1, 0)
		thumb.Position    = UDim2.new(displayT, 0, 0.5, 0)
		valLabel.Text     = step < 1 and string.format("%.1f", val) or tostring(val)
		onChanged(val)
	end

	trackBg.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			applyX(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			applyX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
end

makeSlider("Spawn Distance (studs)", 1, 5,   60,  cfg.spawnDistance,  1,   function(v) cfg.spawnDistance  = v   end)
