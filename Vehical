--  VIEWPORT CAMERA
-- ══════════════════════════════════════════════════════════════════
local rotAngle = 0

local function setupPreview(model)
	if previewConn then
		previewConn:Disconnect()
		previewConn = nil
	end

	for _, child in ipairs(viewportFrame:GetChildren()) do
		if child:IsA("Camera") or child:IsA("Model") then
			child:Destroy()
		end
	end

	if not model then
		noPreviewLabel.Visible = true
		return
	end

	noPreviewLabel.Visible = false

	local clone = model:Clone()
	clone.Parent = viewportFrame

	local cam = Instance.new("Camera")
	cam.Parent = viewportFrame
	viewportFrame.CurrentCamera = cam

	local cf, size = clone:GetBoundingBox()
	local maxDim   = math.max(size.X, size.Y, size.Z)
	local dist     = maxDim * 1.7
	rotAngle       = 0

	previewConn = RunService.RenderStepped:Connect(function(dt)
		rotAngle = rotAngle + dt * 20
		local rot    = CFrame.Angles(0, math.rad(rotAngle), 0)
		local pivot  = CFrame.new(cf.Position) * rot
		local camCF  = pivot:ToWorldSpace(CFrame.new(0, maxDim * 0.28, dist))
		cam.CFrame   = CFrame.new(camCF.Position, cf.Position)
	end)
end

-- ══════════════════════════════════════════════════════════════════
--  VEHICLE LIST
-- ══════════════════════════════════════════════════════════════════
local function selectVehicle(model, btn)
	selectedVehicle = model
	vicNameLabel.Text = model.Name
	setupPreview(model)

	if selectedBtn then
		selectedBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
	end
	selectedBtn = btn
	btn.BackgroundColor3 = Color3.fromRGB(40, 65, 140)
end

local function buildList()
	local vehicles = {}

	for _, child in ipairs(VehicleStorage:GetChildren()) do
		if child:IsA("Model") then
			table.insert(vehicles, child)
		end
	end

	table.sort(vehicles, function(a, b) return a.Name < b.Name end)

	for _, model in ipairs(vehicles) do
		local btn = Instance.new("TextButton")
		btn.Size             = UDim2.new(1, 0, 0, 36)
		btn.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
		btn.BorderSizePixel  = 0
		btn.Text             = model.Name
		btn.TextColor3       = Color3.fromRGB(195, 195, 220)
		btn.TextSize         = 11
		btn.Font             = Enum.Font.Gotham
		btn.TextTruncate     = Enum.TextTruncate.AtEnd
		btn.Parent           = scrollFrame
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

		local btnPad = Instance.new("UIPadding")
		btnPad.PaddingLeft = UDim.new(0, 8)
		btnPad.Parent      = btn

		btn.MouseButton1Click:Connect(function()
			selectVehicle(model, btn)
		end)

		if selectedVehicle == nil then
			selectVehicle(model, btn)
		end
	end

	if #vehicles == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Size               = UDim2.new(1, 0, 0, 36)
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Text               = "No vehicles found"
		emptyLabel.TextColor3         = Color3.fromRGB(70, 70, 90)
		emptyLabel.TextSize           = 11
		emptyLabel.Font               = Enum.Font.Gotham
		emptyLabel.Parent             = scrollFrame
	end
end

buildList()

-- ══════════════════════════════════════════════════════════════════
--  SPAWN
-- ══════════════════════════════════════════════════════════════════
spawnBtn.MouseButton1Click:Connect(function()
	if spawning or not selectedVehicle then return end

	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end

	spawning = true
	spawnBtn.Text             = "SPAWNING..."
	spawnBtn.BackgroundColor3 = Color3.fromRGB(35, 75, 150)

	local root       = char.HumanoidRootPart
	local spawnCFrame = root.CFrame
		* CFrame.new(0, cfg.heightOffset, -cfg.spawnDistance)

	local ok = VehicleSpawn:InvokeServer("Spawn", selectedVehicle, {
		Position       = spawnCFrame,
		SizeMultiplier = cfg.sizeMultiplier,
	})

	if ok then
		spawnBtn.Text             = "SPAWNED!"
		spawnBtn.BackgroundColor3 = Color3.fromRGB(38, 155, 75)
	else
		spawnBtn.Text             = "FAILED"
		spawnBtn.BackgroundColor3 = Color3.fromRGB(155, 38, 38)
	end

	task.wait(1.5)
	spawnBtn.Text             = "SPAWN"
	spawnBtn.BackgroundColor3 = Color3.fromRGB(55, 115, 215)
	spawning = false
end)
